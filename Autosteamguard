    @bot.callback_query_handler(func=lambda call: call.data.startswith(CBT_LOT_COUNT))
    def handle_count(call):
        lot_index = int(call.data.split(":")[1])
        bot.answer_callback_query(call.id)
        msg = bot.send_message(call.message.chat.id, "📦 Введите новое количество для лота:")
        tg.set_state(call.message.chat.id, msg.id, call.from_user.id, WAITING_COUNT, {"lot_index": lot_index})
    
    @bot.callback_query_handler(func=lambda call: call.data.startswith(CBT_LOT_STATUS))
    def handle_status(call):
        lot_index = int(call.data.split(":")[1])
        handle_lot_action(call, "status", lot_index)
    
    @bot.callback_query_handler(func=lambda call: call.data.startswith(CBT_LOT_DESC))
    def handle_desc(call):
        lot_index = int(call.data.split(":")[1])
        bot.answer_callback_query(call.id)
        msg = bot.send_message(call.message.chat.id, "📝 Введите новое описание для лота:")
        tg.set_state(call.message.chat.id, msg.id, call.from_user.id, WAITING_DESC, {"lot_index": lot_index})
    
    @bot.callback_query_handler(func=lambda call: call.data.startswith(CBT_LOT_DELETE))
    def handle_delete(call):
        lot_index = int(call.data.split(":")[1])
        handle_lot_action(call, "delete", lot_index)
    
    @bot.callback_query_handler(func=lambda call: call.data.startswith(CBT_LOT_BACK))
    def handle_back(call):
        parts = call.data.split(":")
        page, filter_type = parts[1], parts[2] if len(parts) > 2 else "all"
        show_lots_menu(call.message, int(page), filter_type)
        bot.answer_callback_query(call.id)
    
    @bot.callback_query_handler(func=lambda call: call.data.startswith(CBT_LOT_PAGE))
    def handle_page(call):
        parts = call.data.split(":")
        page, filter_type = parts[1], parts[2] if len(parts) > 2 else "all"
        show_lots_menu(call.message, int(page), filter_type)
        bot.answer_callback_query(call.id)
    
    @bot.callback_query_handler(func=lambda call: call.data.startswith(CBT_LOT_FILTER))
    def handle_filter(call):
        parts = call.data.split(":")
        filter_type, page = parts[1], parts[2]
        show_lots_menu(call.message, int(page), filter_type)
        bot.answer_callback_query(call.id)
    
    @bot.callback_query_handler(func=lambda call: call.data.startswith(CBT_LOT_RELOAD))
    def handle_reload(call):
        bot.answer_callback_query(call.id, "🔄 Скачиваю лоты...")
        msg = bot.send_message(call.message.chat.id, "🔄 Скачиваю лоты...")
        lots = reload_lots()
        if lots:
            bot.edit_message_text(f"✅ Загружено {len(lots)} лотов", call.message.chat.id, msg.message_id)
        else:
            bot.edit_message_text("❌ Лотов не найдено", call.message.chat.id, msg.message_id)
        show_lots_menu(call.message)
    
    @bot.callback_query_handler(func=lambda call: call.data == "LotManager_Stats")
    def handle_stats(call):
        show_stats(call.message)
        bot.answer_callback_query(call.id)
    
    # Автообновление
    if SETTINGS.get("auto_update", True):
        def auto_updater():
            time.sleep(10)
            while True:
                try:
                    reload_lots()
                    print(f"[LM] 🔄 Автообновление выполнено")
                except Exception as e:
                    print(f"[LM] ❌ Ошибка автообновления: {e}")
                time.sleep(SETTINGS.get("update_interval", 120))
        
        threading.Thread(target=auto_updater, daemon=True).start()
        print(f"[LM] 🔄 Автообновление: {SETTINGS.get('update_interval', 120)}с")
    
    print("[LM] ✅ Плагин загружен!")
    print("[LM] 📌 Команды: /lots, /lot_stats, /lot_load")
    print("=" * 50)

