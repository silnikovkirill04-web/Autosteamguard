def load_config():
    global SETTINGS
    try:
        if os.path.exists(CONFIG_PATH):
            with open(CONFIG_PATH, "r", encoding="utf-8") as f:
                loaded = json.load(f)
                for k in loaded:
                    if k in SETTINGS:
                        SETTINGS[k] = loaded[k]
        else:
            save_config()
    except Exception as e:
        print(f"[LM] ❌ Ошибка загрузки конфига: {e}")
        save_config()

def save_config():
    try:
        os.makedirs(os.path.dirname(CONFIG_PATH), exist_ok=True)
        with open(CONFIG_PATH, "w", encoding="utf-8") as f:
            json.dump(SETTINGS, f, indent=4, ensure_ascii=False)
    except Exception as e:
        print(f"[LM] ❌ Ошибка сохранения: {e}")

def escape_markdown(text):
    if not text:
        return ""
    escape_chars = r'_*[]()~`>#+-=|{}.!'
    return ''.join(f'\\{c}' if c in escape_chars else c for c in text)

def get_user_id():
    """Получает user_id из профиля"""
    try:
        session = cardinal.account.api.session
        response = session.get("https://funpay.com", timeout=10)
        
        if response.status_code != 200:
            return None
        
        match = re.search(r'data-user-id="(\d+)"', response.text)
        if match:
            return match.group(1)
        
        match = re.search(r'/profile/(\d+)/', response.text)
        if match:
            return match.group(1)
        
        return None
    except Exception as e:
        print(f"[LM] ❌ Ошибка получения user_id: {e}")
        return None

def get_all_categories():
    """Парсит все категории с главной страницы"""
    try:
        session = cardinal.account.api.session
        response = session.get("https://funpay.com", timeout=10)
        
        if response.status_code != 200:
            return []
        
        categories = set()
        
        href_matches = re.findall(r'href="[^"]*/(?:category|category/)(\d+)[^"]*"', response.text)
        for cat in href_matches:
            categories.add(cat)
        
        data_matches = re.findall(r'data-category-id="(\d+)"', response.text)
        for cat in data_matches:
            categories.add(cat)
        
        return list(categories)
    except Exception as e:
        print(f"[LM] ❌ Ошибка получения категорий: {e}")
        return []

def parse_lots_from_category(user_id, category_id):
    """Парсит лоты из конкретной категории"""
    try:
        session = cardinal.account.api.session
        url = f"https://funpay.com/category/{category_id}/"
        response = session.get(url, timeout=10)
        
        if response.status_code != 200:
            return []
        
        result = []
        
        lot_pattern = r'data-lot=\'([^\']+)\''
        lot_matches = re.findall(lot_pattern, response.text)
        
        for lot_json in lot_matches:
            try:
                lot_data = json.loads(lot_json)
                
                lot_user_id = lot_data.get("user_id", "")
                if lot_user_id and str(lot_user_id) != str(user_id):
                    continue
                
                fields = lot_data.get("fields", {})
                summary = fields.get("summary", {})
                
                node_id = lot_data.get("node_id", "")
                if not node_id:
                    continue
                
                name = summary.get("ru", summary.get("en", "Без названия"))
                
                price = lot_data.get("price", "0")
                try:
                    price = int(price)
                except:
                    price = 0
                
                amount = lot_data.get("amount", "0")
                try:
                    count = int(amount)
                except:
                    count = 0
                
                active = lot_data.get("active") in ["on", True]
                
                desc = fields.get("desc", {})
                description = desc.get("ru", desc.get("en", ""))
                
                payment_msg = fields.get("payment_msg", {})
                short_desc = payment_msg.get("ru", payment_msg.get("en", ""))
                
                lot_entry = {
                    "id": node_id,
                    "name": name,
                    "price": price,
                    "count": count,
                    "active": active,
                    "description": description,
                    "short_desc": short_desc,
                    "category": f"Категория ID: {category_id}",
                    "category_id": category_id,
                    "updated": datetime.now().strftime("%d.%m.%Y %H:%M:%S")
                }
                
                result.append(lot_entry)
                
            except json.JSONDecodeError:
                continue
            except Exception:
                continue
        
        return result
    except Exception as e:
        print(f"[LM] ⚠️ Ошибка категории {category_id}: {e}")
        return []

def get_lots_from_profile():
    """Глобальный парсинг всех категорий FunPay"""
    try:
        print("[LM] 🔄 ГЛОБАЛЬНЫЙ ПАРСИНГ ВСЕХ КАТЕГОРИЙ...")
        
        user_id = SETTINGS.get("user_id")
        if not user_id:
            user_id = get_user_id()
            if user_id:
                SETTINGS["user_id"] = user_id
                save_config()
                print(f"[LM] 🆔 Найден user_id: {user_id}")
            else:
                print("[LM] ❌ Не удалось найти user_id")
                return []
        
        categories = get_all_categories()
        if not categories:
            print("[LM] ❌ Не найдены категории")
            return []
        
        print(f"[LM] 📂 Найдено {len(categories)} категорий")
        
        all_lots = []
        for i, cat_id in enumerate(categories, 1):
            print(f"[LM] 🔍 Сканирование категории {i}/{len(categories)} (ID: {cat_id})...")
            lots = parse_lots_from_category(user_id, cat_id)
            if lots:
                print(f"[LM] ✅ Найдено {len(lots)} лотов в категории {cat_id}")
                all_lots.extend(lots)
            time.sleep(1)
        
        if all_lots:
            for lot in all_lots:
                SETTINGS["lots_cache"][lot["id"]] = lot
            save_config()
            print(f"[LM] ✅ ВСЕГО НАЙДЕНО: {len(all_lots)} лотов")
        else:
            print("[LM] ❌ Лотов не найдено ни в одной категории")
        
        return all_lots
        
    except Exception as e:
        print(f"[LM] ❌ Сбой глобального парсинга: {e}")
        import traceback
        traceback.print_exc()
        return []

