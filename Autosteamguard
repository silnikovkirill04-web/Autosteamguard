def queue_worker():
    """Обработчик очереди запросов (один поток, строго по очереди)"""
    global queue_worker_running
    
    print("[SG] 🏭 Запущен поток обработки очереди")
    
    while SETTINGS["active"]:
        try:
            task = sg_queue.get(timeout=1)
            if task is None:
                continue
            
            chat_id, order_id, attempt, max_codes, request_timestamp = task
            
            print(f"[SG] 📋 Обработка клиента {chat_id}")
            
            code_found = False
            start_time = time.time()
            timeout = SETTINGS["search_timeout"]
            
            while time.time() - start_time < timeout:
                if not SETTINGS["active"]:
                    break
                
                code = fetch_code_by_time(request_timestamp)
                
                if code:
                    SETTINGS["order_code_counter"][order_id] = SETTINGS["order_code_counter"].get(order_id, 0) + 1
                    SETTINGS["issued_codes"][code] = {
                        "time": datetime.now().strftime("%d.%m.%Y %H:%M:%S"),
                        "chat_id": chat_id
                    }
                    save_config()
                    
                    remaining = max_codes - SETTINGS["order_code_counter"][order_id]
                    start_session(chat_id)
                    
                    elapsed = int(time.time() - start_time)
                    cardinal.send_message(chat_id,
                        f"🎉 Код найден за {elapsed}с!\n\n"
                        f"🔐 Код #{attempt}: {code}\n\n"
                        f"{'📥 Осталось попыток: '+str(remaining) if remaining > 0 else '⚠️ Попыток больше нет!'}\n\n"
                        f"⏰ У вас 10 минут на вход в аккаунт.\n"
                        f"⚠️ После этого код станет недействительным."
                    )
                    code_found = True
                    break
                
                time.sleep(5)
            
            if not code_found:
                cardinal.send_message(chat_id,
                    f"⏰ Код не найден за {int(timeout/60)} минут.\n"
                    f"🔄 Попробуйте войти в Steam еще раз и отправьте SGC снова."
                )
            
            sg_queue.task_done()
            
        except queue.Empty:
            continue
        except Exception as e:
            print(f"[SG] Ошибка в очереди: {e}")
            try:
                sg_queue.task_done()
            except:
                pass
            time.sleep(1)

