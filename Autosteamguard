def load_config():
    global SETTINGS
    try:
        if os.path.exists(CONFIG_PATH):
            with open(CONFIG_PATH, "r", encoding="utf-8") as f:
                loaded = json.load(f)
                for k in loaded:
                    if k in SETTINGS:
                        SETTINGS[k] = loaded[k]
    except: pass

def save_config():
    try:
        os.makedirs(os.path.dirname(CONFIG_PATH), exist_ok=True)
        with open(CONFIG_PATH, "w", encoding="utf-8") as f:
            json.dump(SETTINGS, f, indent=4, ensure_ascii=False)
    except: pass

def get_imap():
    try:
        conn = imaplib.IMAP4_SSL(SETTINGS["imap_host"], SETTINGS["imap_port"], timeout=10)
        conn.login(SETTINGS["imap_login"], SETTINGS["imap_password"])
        conn.select("INBOX")
        return conn
    except:
        return None

def check_mail():
    try:
        conn = imaplib.IMAP4_SSL(SETTINGS["imap_host"], SETTINGS["imap_port"], timeout=10)
        conn.login(SETTINGS["imap_login"], SETTINGS["imap_password"])
        conn.select("INBOX")
        _, mails = conn.search(None, "ALL")
        count = len(mails[0].split()) if mails[0] else 0
        conn.logout()
        SETTINGS["mail_status"] = True
        SETTINGS["mail_count"] = count
        SETTINGS["mail_last_check"] = datetime.now().strftime("%d.%m.%Y %H:%M:%S")
        save_config()
        return True, count
    except:
        SETTINGS["mail_status"] = False
        save_config()
        return False, 0

def fetch_code():
    conn = get_imap()
    if not conn: return None
    try:
        _, mail_ids = conn.search(None, f'FROM "{SETTINGS["steam_sender"]}"')
        if not mail_ids[0]: 
            conn.close(); conn.logout(); return None
        
        for mail_id in reversed(mail_ids[0].split()[-5:]):
            _, raw = conn.fetch(mail_id, "(RFC822)")
            mail_obj = email.message_from_bytes(raw[0][1])
            
            subject = mail_obj.get("Subject", "").lower()
            if any(w in subject for w in BLOCKED_SUBJECTS):
                continue
            
            body = ""
            if mail_obj.is_multipart():
                for part in mail_obj.walk():
                    if part.get_content_type() == "text/plain":
                        body = part.get_payload(decode=True).decode("utf-8", errors="ignore")
                        break
            else:
                body = mail_obj.get_payload(decode=True).decode("utf-8", errors="ignore")
            
            body_lower = body.lower()
            if any(w in body_lower for w in BLOCKED_BODY):
                continue
            
            codes = re.findall(r"\b[A-Z0-9]{5}\b", body)
            if codes and any(kw in body_lower for kw in GUARD_KEYWORDS):
                conn.store(mail_id, "+FLAGS", "\\Seen")
                return codes[0]
        return None
    except: return None
    finally:
        try: conn.close(); conn.logout()
        except: pass

def chat_scanner():
    processed = {}
    while True:
        if not SETTINGS["active"]: time.sleep(1); continue
        try:
            now = time.time()
            timeout = SETTINGS["search_timeout"]
            
            for chat_id in list(active_searches.keys()):
                search = active_searches[chat_id]
                elapsed = now - search["start_time"]
                
                if elapsed > timeout:
                    cardinal.send_message(chat_id,
                        f"⏰ Время поиска истекло (5 минут)\n"
                        f"Код не найден. Попытка НЕ потрачена.\n"
                        f"🔄 Отправьте SGC снова."
                    )
                    del active_searches[chat_id]
                    continue
                
                code = fetch_code()
                if code:
                    order_id = search["order_id"]
                    attempt = search["attempt"]
                    SETTINGS["order_code_counter"][order_id] = SETTINGS["order_code_counter"].get(order_id, 0) + 1
                    SETTINGS["issued_codes"][code] = {"time": datetime.now().strftime("%d.%m.%Y %H:%M:%S")}
                    save_config()
                    
                    remaining = SETTINGS["max_codes_per_order"] - SETTINGS["order_code_counter"][order_id]
                    cardinal.send_message(chat_id,
                        f"🎉 Код найден за {int(elapsed)}с!\n\n"
                        f"🔐 Код #{attempt}: {code}\n\n"
                        f"{'📥 Осталось попыток: '+str(remaining) if remaining > 0 else '⚠️ Попыток больше нет!'}"
                    )
                    del active_searches[chat_id]
                    continue
                
                if elapsed - search.get("last_notify", 0) > 30:
                    search["last_notify"] = elapsed
                    cardinal.send_message(chat_id, f"⏳ Ищу код... {int(elapsed)}с из {timeout}с | Попытка #{search['attempt']}")
            
            chats = cardinal.account.get_chats(update=True)
            if not chats: time.sleep(1); continue
            
            for chat_id, chat in chats.items():
                if not chat.unread: continue
                
                try: msgs = cardinal.account.get_chat_history(chat_id)
                except: continue
                if not msgs: continue
                
                buyer_text = ""; msg_id = 0
                for msg in reversed(msgs):
                    if hasattr(msg, "author_id") and msg.author_id not in (cardinal.account.id, 0):
                        if msg.text and msg.text.strip():
                            buyer_text = msg.text.strip(); msg_id = msg.id
                            break
                
                if not buyer_text: continue
                if buyer_text.upper().strip() != "SGC": continue
                
                if chat_id in processed and processed[chat_id] >= msg_id: continue
                if chat_id in active_searches:
                    cardinal.send_message(chat_id, "⏳ Уже ищу код для вас! Ожидайте.")
                    processed[chat_id] = msg_id; continue
                
                order_id = f"chat_{chat_id}"
                order_cnt = SETTINGS["order_code_counter"].get(order_id, 0)
                max_codes = SETTINGS["max_codes_per_order"]
                
                if order_cnt >= max_codes:
                    cardinal.send_message(chat_id, f"⚠️ Уже выдано {max_codes} кода. Лимит исчерпан.")
                    processed[chat_id] = msg_id; continue
                
                attempt = order_cnt + 1
                code = fetch_code()
                if code:
                    SETTINGS["order_code_counter"][order_id] = order_cnt + 1
                    SETTINGS["issued_codes"][code] = {"time": datetime.now().strftime("%d.%m.%Y %H:%M:%S")}
                    save_config()
                    remaining = max_codes - order_cnt - 1
                    cardinal.send_message(chat_id,
                        f"⚡ Код найден мгновенно!\n\n"
                        f"🔐 Код #{attempt}: {code}\n\n"
                        f"{'📥 Осталось попыток: '+str(remaining) if remaining > 0 else '⚠️ Попыток больше нет!'}"
                    )
                    processed[chat_id] = msg_id; continue
                
                cardinal.send_message(chat_id,
                    f"🔍 Поиск кода #{attempt}\n"
                    f"⏱ Максимум 5 минут\n"
                    f"📥 Осталось попыток: {max_codes - attempt}\n"
                    f"❌ Кода пока нет — жду..."
                )
                
                active_searches[chat_id] = {
                    "order_id": order_id, "attempt": attempt,
                    "start_time": time.time(), "last_notify": 0
                }
                processed[chat_id] = msg_id
            
            if len(processed) > 100: processed = dict(list(processed.items())[-50:])
            time.sleep(1)
            
        except Exception as e:
            print(f"[SG] Ошибка: {e}"); time.sleep(2)

