def init_plugin(c):
    global cardinal, tg, bot
    cardinal = c
    tg = c.telegram
    bot = c.telegram.bot
    
    print("=" * 50)
    print("[LM] 📦 ЗАГРУЗКА Lot Manager v1.2")
    print("=" * 50)
    
    load_config()
    
    # Регистрация команд
    c.add_telegram_commands(UUID, [
        ("lots", "📦 Управление лотами", True),
        ("lot_stats", "📊 Статистика лотов", True),
        ("lot_load", "📥 Загрузить лоты", True)
    ])
    
    # Обработчики команд
    tg.msg_handler(lambda m: show_lots_menu(m), commands=["lots"])
    tg.msg_handler(lambda m: show_stats(m), commands=["lot_stats"])
    tg.msg_handler(lambda m: show_lots_menu(m), commands=["lot_load"])
    
    # Обработчик ввода
    tg.msg_handler(handle_input, func=lambda m: tg.check_state(m.chat.id, m.from_user.id))
    
    # Обработчики кнопок
    @bot.callback_query_handler(func=lambda call: call.data.startswith(CBT_LOT_LIST))
    def handle_list(call):
        show_lots_menu(call.message)
        bot.answer_callback_query(call.id)
    
    @bot.callback_query_handler(func=lambda call: call.data.startswith(CBT_LOT_EDIT))
    def handle_edit(call):
        parts = call.data.split(":")
        lot_id, page, filter_type = parts[1], parts[2], parts[3] if len(parts) > 3 else "all"
        show_lot_edit(call.message, lot_id, page, filter_type)
        bot.answer_callback_query(call.id)
    
    @bot.callback_query_handler(func=lambda call: call.data.startswith(CBT_LOT_PRICE))
    def handle_price(call):
        parts = call.data.split(":")
