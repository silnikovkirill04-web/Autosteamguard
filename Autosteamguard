def get_lot_name(lot):
    return lot.get("name", "Без названия")

def get_lot_price(lot):
    return lot.get("price", "0")

def get_lot_amount(lot):
    return lot.get("amount", "0")

def get_lot_active(lot):
    return lot.get("active") == "on"

def get_lot_type(lot):
    return lot.get("type", "?")

def get_lot_node(lot):
    return lot.get("node_id", "?")

def get_lot_offer_id(lot):
    return lot.get("offer_id", "")

def get_lot_subcategory(lot):
    return lot.get("subcategory", "Без категории")

