def chat_scanner():
    """Сканер новых сообщений (ставит запросы в очередь)"""
    processed = {}
    while True:
        if not SETTINGS["active"]:
            time.sleep(1)
            continue
        try:
            chats = cardinal.account.get_chats(update=True)
            if not chats:
                time.sleep(1)
                continue
            
            for chat_id, chat in chats.items():
                if not chat.unread:
                    continue
                
                try:
                    msgs = cardinal.account.get_chat_history(chat_id)
                except:
                    continue
                if not msgs:
                    continue
                
                buyer_text = ""
                msg_id = 0
                for msg in reversed(msgs):
                    if hasattr(msg, "author_id") and msg.author_id not in (cardinal.account.id, 0):
                        if msg.text and msg.text.strip():
                            buyer_text = msg.text.strip()
                            msg_id = msg.id
                            break
                
                if not buyer_text:
                    continue
                if buyer_text.upper().strip() != "SGC":
                    continue
                
                # 🔥 ПРОВЕРКА: уже обработано?
                if chat_id in processed and processed[chat_id] >= msg_id:
                    continue
                
                order_id = f"chat_{chat_id}"
                order_cnt = SETTINGS["order_code_counter"].get(order_id, 0)
                max_codes = SETTINGS["max_codes_per_order"]
                
                if order_cnt >= max_codes:
                    cardinal.send_message(chat_id, f"⚠️ Уже выдано {max_codes} кода. Лимит исчерпан.")
                    processed[chat_id] = msg_id
                    continue
                
                attempt = order_cnt + 1
                
                # 🔥 СТАВИМ В ОЧЕРЕДЬ И ПОМЕЧАЕМ КАК ОБРАБОТАННОЕ
                on_client_request(chat_id, order_id, attempt, max_codes)
                processed[chat_id] = msg_id
                
                # 🔥 ПЫТАЕМСЯ ОТМЕТИТЬ КАК ПРОЧИТАННОЕ (если есть метод)
                try:
                    if hasattr(cardinal.account, 'mark_as_read'):
                        cardinal.account.mark_as_read(chat_id)
                except:
                    pass
            
            if len(processed) > 100:
                processed = dict(list(processed.items())[-50:])
            time.sleep(1)
            
        except Exception as e:
            print(f"[SG] Ошибка сканера: {e}")
            time.sleep(2)

