def handle_delete_confirm(call, lot_id, page, filter_type):
    try:
        if delete_lot(lot_id):
            if lot_id in SETTINGS["lots_cache"]:
                del SETTINGS["lots_cache"][lot_id]
                save_config()
            
            bot.edit_message_text(f"✅ **Лот {lot_id} успешно удален!**", call.message.chat.id, call.message.id)
            bot.answer_callback_query(call.id, "🗑️ Лот удален!")
            show_lots_menu(call.message, int(page), filter_type)
        else:
            bot.edit_message_text(f"❌ **Ошибка при удалении лота {lot_id}**", call.message.chat.id, call.message.id)
            bot.answer_callback_query(call.id, "❌ Ошибка удаления")
    except Exception as e:
        bot.edit_message_text(f"❌ **Ошибка:** {e}", call.message.chat.id, call.message.id)
        bot.answer_callback_query(call.id, "❌ Ошибка")

