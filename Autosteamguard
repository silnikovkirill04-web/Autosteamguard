def show_lots_menu(message, page=0, filter_type="all"):
    """Показывает список лотов (как в MASSedit)"""
    
    lots = load_cache()
    
    if not lots:
        loading_msg = bot.send_message(message.chat.id, "🔄 Скачиваю лоты...")
        lots = reload_lots()
        if not lots:
            bot.edit_message_text("❌ Лотов не найдено", message.chat.id, loading_msg.id)
            kb = InlineKeyboardMarkup()
            kb.add(InlineKeyboardButton("🔄 Скачать", callback_data=f"{CBT_LOT_RELOAD}"))
            kb.add(InlineKeyboardButton("📝 Создать лот на FunPay", url="https://funpay.com/sell/"))
            bot.send_message(
                message.chat.id,
                "❌ Лотов не найдено.\n\n"
                "💡 Проверь:\n"
                "1. Есть ли у тебя созданные лоты на FunPay\n"
                "2. Правильный ли golden_key в Cardinal\n"
                "3. Сессия FunPay активна",
                reply_markup=kb
            )
            return
        bot.delete_message(message.chat.id, loading_msg.id)
    
    # Фильтрация
    if filter_type == "active":
        filtered = [l for l in lots if get_lot_active(l)]
    elif filter_type == "inactive":
        filtered = [l for l in lots if not get_lot_active(l)]
    else:
        filtered = lots
    
    # Сортировка: активные сверху
    sorted_lots = sorted(filtered, key=lambda l: (not get_lot_active(l), get_lot_name(l)))
    
    total = len(sorted_lots)
    total_pages = max(1, (total + PER_PAGE - 1) // PER_PAGE)
    if page >= total_pages:
        page = total_pages - 1
    if page < 0:
        page = 0
    
    start = page * PER_PAGE
    end = min(start + PER_PAGE, total)
    page_lots = sorted_lots[start:end]
    
    total_active = len([l for l in lots if get_lot_active(l)])
    total_inactive = len([l for l in lots if not get_lot_active(l)])
    
    filter_names = {
        "all": "Все",
        "active": "🟢 Активные",
        "inactive": "🔴 Неактивные"
    }
    
    text = f"📋 **Список лотов**\n"
    text += f"📂 {filter_names.get(filter_type, 'Все')} | стр. {page + 1}/{total_pages}\n"
    text += f"📊 Всего: {total} | 🟢 Активных: {total_active} | 🔴 Неактивных: {total_inactive}\n\n"
    
    if not page_lots:
        text += "❌ Нет лотов в этой категории\n"
    else:
        for i, lot in enumerate(page_lots, 1):
            idx = start + i
            name = escape_markdown(get_lot_name(lot)[:35])
            status = "✅" if get_lot_active(lot) else "❌"
            price = get_lot_price(lot)
            amount = get_lot_amount(lot)
            lot_type = get_lot_type(lot)
            node = get_lot_node(lot)
            
            text += f"{idx}. {status} [{lot_type}] #{node}\n"
            text += f"   `{name}`\n"
            text += f"   💵 {price}₽ | 📦 {amount} шт.\n\n"
    
    kb = InlineKeyboardMarkup(row_width=1)
    
    # 🔥 Кнопки с названиями лотов
    for i, lot in enumerate(page_lots):
        idx = start + i
        name = escape_markdown(get_lot_name(lot)[:30])
        price = get_lot_price(lot)
        kb.add(InlineKeyboardButton(
            f"📝 `{name}` | {price}₽",
            callback_data=f"{CBT_LOT_LOT}_{idx}"
        ))
    
    # Навигация
    nav = []
    if page > 0:
        nav.append(InlineKeyboardButton("⬅️", callback_data=f"{CBT_LOT_PAGE}:{page - 1}:{filter_type}"))
    if page < total_pages - 1:
        nav.append(InlineKeyboardButton("➡️", callback_data=f"{CBT_LOT_PAGE}:{page + 1}:{filter_type}"))
    if nav:
        kb.row(*nav)
    
    # Кнопки фильтрации
    kb.row(
        InlineKeyboardButton("📂 Все", callback_data=f"{CBT_LOT_FILTER}:all:0"),
        InlineKeyboardButton("🟢 Активные", callback_data=f"{CBT_LOT_FILTER}:active:0"),
        InlineKeyboardButton("🔴 Неактивные", callback_data=f"{CBT_LOT_FILTER}:inactive:0")
    )
    
    # Общие кнопки
    kb.row(
        InlineKeyboardButton("🔄 Скачать", callback_data=f"{CBT_LOT_RELOAD}"),
        InlineKeyboardButton("📊 Статистика", callback_data="LotManager_Stats")
    )
    
    bot.send_message(message.chat.id, text, reply_markup=kb, parse_mode="Markdown")

