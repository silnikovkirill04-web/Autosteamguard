def show_lots_menu(message, page=0, filter_type="all"):
    """Показывает список лотов с пагинацией и фильтрацией"""
    
    # Загружаем лоты из профиля
    loading_msg = bot.send_message(message.chat.id, "⏳ Загрузка лотов из профиля...")
    lots = get_lots_from_profile()
    
    if not lots:
        bot.edit_message_text("❌ Нет доступных лотов или ошибка подключения к FunPay", message.chat.id, loading_msg.id)
        kb = InlineKeyboardMarkup()
        kb.add(InlineKeyboardButton("🔄 Попробовать снова", callback_data=f"{CBT_LOT_LOAD}:0:all"))
        cardinal.send_message(message.chat.id, "❌ Лотов не найдено", reply_markup=kb)
        return
    
    bot.delete_message(message.chat.id, loading_msg.id)
    
    # Фильтрация
    if filter_type == "active":
        filtered = [l for l in lots if l["active"]]
    elif filter_type == "inactive":
        filtered = [l for l in lots if not l["active"]]
    else:
        filtered = lots
    
    # Сортировка: активные сверху
    active_lots = [l for l in filtered if l["active"]]
    inactive_lots = [l for l in filtered if not l["active"]]
    sorted_lots = active_lots + inactive_lots
    
    # Пагинация (по 5 лотов на страницу)
    per_page = 5
    total_pages = (len(sorted_lots) + per_page - 1) // per_page
    if total_pages == 0:
        total_pages = 1
    if page >= total_pages:
        page = total_pages - 1
    if page < 0:
        page = 0
    
    start = page * per_page
    end = min(start + per_page, len(sorted_lots))
    page_lots = sorted_lots[start:end]
    
    # Формируем текст
    total = len(lots)
    total_active = len([l for l in lots if l["active"]])
    total_inactive = len([l for l in lots if not l["active"]])
    
    filter_names = {
        "all": "Все",
        "active": "🟢 Активные",
        "inactive": "🔴 Неактивные"
    }
    
    text = f"📋 **Список лотов**\n"
    text += f"📂 {filter_names.get(filter_type, 'Все')} | стр. {page + 1}/{total_pages}\n"
    text += f"📊 Всего: {total} | 🟢 Активных: {total_active} | 🔴 Неактивных: {total_inactive}\n\n"
    
    if not page_lots:
        text += "❌ Нет лотов в этой категории\n"
    else:
        for i, lot in enumerate(page_lots, start + 1):
            name = escape_markdown(lot['name'])
            category = escape_markdown(lot.get('category', 'Без категории'))
            status_icon = "🟢" if lot['active'] else "🔴"
            status_text = "Активен" if lot['active'] else "Неактивен"
            
            text += f"**{i}. {status_icon} `{name}`**\n"
            text += f"   💰 {lot['price']}₽ | 📦 {lot['count']} шт.\n"
            text += f"   📌 {status_icon} {status_text}\n"
            text += f"   📂 {category}\n"
            text += f"   🆔 `{lot['id']}`\n\n"
    
    # Клавиатура
    kb = InlineKeyboardMarkup(row_width=3)
    
    # Кнопки фильтрации
    kb.row(
        InlineKeyboardButton("📂 Все", callback_data=f"{CBT_LOT_FILTER}:all:{page}"),
        InlineKeyboardButton("🟢 Активные", callback_data=f"{CBT_LOT_FILTER}:active:{page}"),
        InlineKeyboardButton("🔴 Неактивные", callback_data=f"{CBT_LOT_FILTER}:inactive:{page}")
    )
    
    # Кнопки навигации
    nav_buttons = []
    if page > 0:
        nav_buttons.append(InlineKeyboardButton("◀️", callback_data=f"{CBT_LOT_PAGE}:{page - 1}:{filter_type}"))
    if page < total_pages - 1:
        nav_buttons.append(InlineKeyboardButton("▶️", callback_data=f"{CBT_LOT_PAGE}:{page + 1}:{filter_type}"))
    if nav_buttons:
        kb.row(*nav_buttons)
    
    # Кнопки действий для каждого лота
    for lot in page_lots:
        lot_id = lot["id"]
        name_short = escape_markdown(lot['name'][:12])
        status_btn = "🔴 Выкл" if lot["active"] else "🟢 Вкл"
        kb.row(
            InlineKeyboardButton(f"✏️ {name_short}", callback_data=f"{CBT_LOT_EDIT}:{lot_id}:{page}:{filter_type}"),
            InlineKeyboardButton(status_btn, callback_data=f"{CBT_LOT_STATUS}:{lot_id}:{page}:{filter_type}")
        )
    
    # Общие кнопки
    kb.row(
        InlineKeyboardButton("🔄 Обновить", callback_data=f"{CBT_LOT_REFRESH}:{page}:{filter_type}"),
        InlineKeyboardButton("📥 Загрузить", callback_data=f"{CBT_LOT_LOAD}:{page}:{filter_type}")
    )
    kb.row(
        InlineKeyboardButton("📊 Статистика", callback_data="LotManager_Stats"),
        InlineKeyboardButton("🔄 Синхронизировать", callback_data=f"{CBT_LOT_UPDATE}:{page}:{filter_type}")
    )
    
    cardinal.send_message(message.chat.id, text, reply_markup=kb, parse_mode="Markdown")

