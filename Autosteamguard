def fetch_code_by_time(request_timestamp):
    """
    Ищет код в письмах, которые пришли ПОСЛЕ запроса клиента
    Это гарантирует, что код не будет выдан другому клиенту
    """
    conn = get_imap()
    if not conn: 
        return None
    
    try:
        _, mail_ids = conn.search(None, f'UNSEEN FROM "{SETTINGS["steam_sender"]}"')
        if not mail_ids[0]:
            conn.close()
            conn.logout()
            return None
        
        for mail_id in reversed(mail_ids[0].split()[-5:]):
            _, raw = conn.fetch(mail_id, "(RFC822)")
            mail_obj = email.message_from_bytes(raw[0][1])
            
            # 🔥 Проверяем ДАТУ письма
            date_str = mail_obj.get("Date", "")
            try:
                from email.utils import parsedate_to_datetime
                mail_date = parsedate_to_datetime(date_str)
                mail_date = mail_date.replace(tzinfo=None)
                mail_timestamp = mail_date.timestamp()
                
                if mail_timestamp < request_timestamp:
                    print(f"[SG] Пропускаю старое письмо")
                    continue
            except:
                pass
            
            subject = mail_obj.get("Subject", "").lower()
            if any(w in subject for w in BLOCKED_SUBJECTS):
                continue
            
            body = ""
            if mail_obj.is_multipart():
                for part in mail_obj.walk():
                    if part.get_content_type() == "text/plain":
                        body = part.get_payload(decode=True).decode("utf-8", errors="ignore")
                        break
            else:
                body = mail_obj.get_payload(decode=True).decode("utf-8", errors="ignore")
            
            body_lower = body.lower()
            
            if any(w in body_lower for w in BLOCKED_BODY):
                continue
            
            code_match = re.search(r'^\s*([A-Z0-9]{5})\s*$', body, re.MULTILINE)
            if not code_match:
                code_match = re.search(r'код\s*[:.]?\s*([A-Z0-9]{5})', body_lower)
            if not code_match:
                code_match = re.search(r'\b([A-Z0-9]{5})\b', body)
            
            if code_match:
                code = code_match.group(1) if len(code_match.groups()) > 0 else code_match.group(0)
                code = code.upper()
                
                if any(kw in body_lower for kw in GUARD_KEYWORDS):
                    if SETTINGS.get("delete_after_use", True):
                        conn.store(mail_id, "+FLAGS", "\\Deleted")
                        conn.expunge()
                        print(f"[SG] 🗑️ Письмо с кодом {code} удалено")
                    else:
                        conn.store(mail_id, "+FLAGS", "\\Seen")
                    conn.close()
                    conn.logout()
                    return code
        
        conn.close()
        conn.logout()
        return None
        
    except Exception as e:
        print(f"[SG] Ошибка fetch_code_by_time: {e}")
        try:
            conn.close()
            conn.logout()
        except:
            pass
        return None

