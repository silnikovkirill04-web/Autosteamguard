def on_client_request(chat_id, order_id, attempt, max_codes):
    """Обработка запроса SGC от клиента (ставка в очередь)"""
    request_timestamp = time.time()
    
    sg_queue.put((chat_id, order_id, attempt, max_codes, request_timestamp))
    
    queue_position = sg_queue.qsize()
    cardinal.send_message(chat_id,
        f"⏳ Ваш запрос принят!\n"
        f"📋 Позиция в очереди: {queue_position}\n"
        f"⏱ Ожидайте, бот обрабатывает запросы по очереди..."
    )

def process_sgc(chat_id, msg_id):
    """Обработка запроса SGC через очередь"""
    order_id = f"chat_{chat_id}"
    order_cnt = SETTINGS["order_code_counter"].get(order_id, 0)
    max_codes = SETTINGS["max_codes_per_order"]
    
    if order_cnt >= max_codes:
        cardinal.send_message(chat_id, f"⚠️ Уже выдано {max_codes} кода. Лимит исчерпан.")
        return
    
    attempt = order_cnt + 1
    on_client_request(chat_id, order_id, attempt, max_codes)

