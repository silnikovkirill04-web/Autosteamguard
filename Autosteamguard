def reload_lots():
    """Скачивает лоты из FunPay (как в MASSedit)"""
    try:
        print("[LM] 🔄 Скачивание лотов из FunPay...")
        
        if not cardinal.account:
            print("[LM] ❌ Аккаунт не авторизован")
            return []
        
        cache = []
        subcats = []
        
        # 🔥 Собираем ВСЕ подкатегории с лотами
        try:
            categories = cardinal.account.categories
            if not categories:
                print("[LM] ❌ Не удалось получить категории")
                return []
            
            for cat in categories:
                try:
                    subcats_list = cat.get_subcategories()
                    for sub in subcats_list:
                        # Только COMMON (обычные лоты)
                        if hasattr(sub, 'type') and sub.type.value == 0:
                            subcats.append(sub)
                        elif not hasattr(sub, 'type'):
                            subcats.append(sub)
                except Exception as e:
                    print(f"[LM] ⚠️ Ошибка категории {cat}: {e}")
        except Exception as e:
            print(f"[LM] ⚠️ Ошибка получения категорий: {e}")
            # Пробуем альтернативный способ
            try:
                subcats = cardinal.account.get_subcategories()
            except:
                pass
        
        print(f"[LM] 📂 Найдено {len(subcats)} подкатегорий")
        
        # 🔥 Запрашиваем лоты в каждой подкатегории
        for idx, sub in enumerate(subcats):
            try:
                sub_id = sub.id if hasattr(sub, 'id') else str(sub)
                sub_name = sub.ui_name if hasattr(sub, 'ui_name') else str(sub)
                
                sub_lots = cardinal.account.get_my_subcategory_lots(sub_id)
                if sub_lots:
                    for lot in sub_lots:
                        cache.append({
                            "offer_id": str(lot.id),
                            "name": lot.description or "?",
                            "price": str(lot.price or 0),
                            "amount": str(lot.amount or 0),
                            "active": "on" if lot.active else "",
                            "type": "?",
                            "node_id": str(sub_id),
                            "subcategory": sub_name
                        })
                
                # Прогресс каждые 10 категорий
                if idx % 10 == 0:
                    print(f"[LM] 🔍 Обработано {idx+1}/{len(subcats)}, найдено {len(cache)} лотов")
                    
            except Exception as e:
                print(f"[LM] ⚠️ Ошибка подкатегории {idx}: {e}")
                continue
        
        # 🔥 Дозаполняем типы для первых 50 лотов
        print("[LM] 📝 Заполнение типов лотов...")
        for idx, lot in enumerate(cache[:50]):
            try:
                time.sleep(0.15)
                fields = cardinal.account.get_lot_fields(lot["offer_id"])
                if fields and hasattr(fields, 'fields'):
                    lot["type"] = fields.fields.get("fields[type]", "?")
                else:
                    lot["type"] = "?"
            except Exception as e:
                lot["type"] = "?"
        
        if cache:
            save_cache(cache)
            SETTINGS["lots_cache"] = cache
            save_config()
            print(f"[LM] ✅ Загружено {len(cache)} лотов")
        else:
            print("[LM] ❌ Лотов не найдено")
        
        return cache
        
    except Exception as e:
        print(f"[LM] ❌ Сбой загрузки: {e}")
        import traceback
        traceback.print_exc()
        return []

def get_lots_from_profile():
    """Возвращает лоты из кэша или загружает новые"""
    lots = load_cache()
    if not lots:
        lots = reload_lots()
    return lots

