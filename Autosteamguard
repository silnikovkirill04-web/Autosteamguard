def init_plugin(c):
    global cardinal, tg, bot
    cardinal = c
    tg = c.telegram
    bot = c.telegram.bot
    load_config()
    
    ok, count = check_mail()
    print(f"[SteamGuard] {'✅' if ok else '❌'} Почта | Писем: {count}")
    
    # 🔥 РЕГИСТРИРУЕМ КОМАНДУ
    try:
        c.add_telegram_commands(UUID, [("sg", "🔐 SteamGuard", True)])
        print("[SteamGuard] ✅ Команда /sg зарегистрирована")
    except Exception as e:
        print(f"[SteamGuard] ❌ Ошибка регистрации команды: {e}")
    
    # 🔥 РЕГИСТРИРУЕМ ОБРАБОТЧИК
    try:
        tg.msg_handler(show_menu, commands=["sg"])
        print("[SteamGuard] ✅ Обработчик /sg зарегистрирован")
    except Exception as e:
        print(f"[SteamGuard] ❌ Ошибка регистрации обработчика: {e}")
    
    # 🔥 КНОПКИ
    @bot.callback_query_handler(func=lambda call: call.data == "sg_toggle")
    def toggle(call):
        SETTINGS["active"] = not SETTINGS["active"]
        save_config()
        bot.answer_callback_query(call.id, f"{'ON' if SETTINGS['active'] else 'OFF'}")
        show_menu(call.message)
    
    @bot.callback_query_handler(func=lambda call: call.data == "sg_refresh")
    def refresh(call):
        bot.answer_callback_query(call.id, "Обновляю...")
        show_menu(call.message)
    
    # 🔥 ЗАПУСКАЕМ СКАНЕР
    threading.Thread(target=chat_scanner, daemon=True).start()
    
    print(f"[SteamGuard v{VERSION}] Загружен. /sg — меню | SGC — запрос кода")

