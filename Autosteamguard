def get_imap():
    try:
        conn = imaplib.IMAP4_SSL(SETTINGS["imap_host"], SETTINGS["imap_port"], timeout=15)
        conn.login(SETTINGS["imap_login"], SETTINGS["imap_password"])
        conn.select("INBOX")
        return conn
    except Exception as e:
        print(f"[SG] ❌ Ошибка подключения: {e}")
        return None

def check_mail():
    try:
        conn = get_imap()
        if not conn:
            return False, 0
        _, mails = conn.search(None, "ALL")
        count = len(mails[0].split()) if mails[0] else 0
        conn.close()
        conn.logout()
        SETTINGS["mail_status"] = True
        SETTINGS["mail_count"] = count
        SETTINGS["mail_last_check"] = datetime.now().strftime("%d.%m.%Y %H:%M:%S")
        save_config()
        print(f"[SG] ✅ Почта: {count} писем")
        return True, count
    except Exception as e:
        print(f"[SG] ❌ Ошибка проверки почты: {e}")
        SETTINGS["mail_status"] = False
        save_config()
        return False, 0

# ============================================
# 🔥 ПОИСК КОДА (UNSEEN + УДАЛЕНИЕ)
# ============================================

def fetch_code_by_time(request_timestamp):
    """
    Ищет код ТОЛЬКО в НЕПРОЧИТАННЫХ письмах от Steam
    Удаляет письмо после выдачи
    """
    conn = get_imap()
    if not conn:
        return None
    
    try:
        # 🔥 Ищем ТОЛЬКО НЕПРОЧИТАННЫЕ письма
        _, mail_ids = conn.search(None, f'UNSEEN FROM "{SETTINGS["steam_sender"]}"')
        if not mail_ids[0]:
            conn.close()
            conn.logout()
            return None
        
        print(f"[SG] 📬 Найдено {len(mail_ids[0].split())} новых писем от Steam")
        
        # Проверяем последние 5
        for mail_id in reversed(mail_ids[0].split()[-5:]):
            try:
                _, raw = conn.fetch(mail_id, "(RFC822)")
                mail_obj = email.message_from_bytes(raw[0][1])
                
                subject = mail_obj.get("Subject", "").lower()
                if any(w in subject for w in BLOCKED_SUBJECTS):
                    continue
                
                body = ""
                if mail_obj.is_multipart():
                    for part in mail_obj.walk():
                        if part.get_content_type() == "text/plain":
                            body = part.get_payload(decode=True).decode("utf-8", errors="ignore")
                            break
                else:
                    body = mail_obj.get_payload(decode=True).decode("utf-8", errors="ignore")
                
                body_lower = body.lower()
                
                if any(w in body_lower for w in BLOCKED_BODY):
                    continue
                
                # Ищем код
                codes = re.findall(r"\b[A-Z0-9]{5}\b", body)
                
                if codes and any(kw in body_lower for kw in GUARD_KEYWORDS):
                    code = codes[0].upper()
                    print(f"[SG] 🎉 КОД НАЙДЕН: {code}")
                    
                    # 🔥 УДАЛЯЕМ письмо
                    if SETTINGS.get("delete_after_use", True):
                        conn.store(mail_id, "+FLAGS", "\\Deleted")
                        conn.expunge()
                        print(f"[SG] 🗑️ Письмо с кодом {code} УДАЛЕНО")
                    else:
                        conn.store(mail_id, "+FLAGS", "\\Seen")
                        print(f"[SG] 📌 Письмо помечено как прочитанное")
                    
                    conn.close()
                    conn.logout()
                    return code
                    
            except Exception as e:
                print(f"[SG] ❌ Ошибка обработки письма: {e}")
                continue
        
        conn.close()
        conn.logout()
        return None
        
    except Exception as e:
        print(f"[SG] ❌ Критическая ошибка: {e}")
        try:
            conn.close()
            conn.logout()
        except:
            pass
        return None

