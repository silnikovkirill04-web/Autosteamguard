    lots = get_cached_lots() or get_lots_from_profile()
    if not lots:
        bot.send_message(message.chat.id, "❌ Нет данных. Нажмите 'Сканировать'")
        return
    
    total = len(lots)
    active = len([l for l in lots if l.get('active', False)])
    inactive = len([l for l in lots if not l.get('active', False)])
    
    total_price = sum(l.get('price', 0) for l in lots)
    total_count = sum(l.get('count', 0) for l in lots)
    avg_price = total_price // total if total > 0 else 0
    
    categories = {}
    for lot in lots:
        cat = lot.get("category", "Без категории")
        categories[cat] = categories.get(cat, 0) + 1
    
    text = f"📊 **Статистика лотов**\n\n"
    text += f"📌 **Всего лотов:** {total}\n"
    text += f"🟢 **Активных:** {active}\n"
    text += f"🔴 **Неактивных:** {inactive}\n"
    text += f"💰 **Общая стоимость:** {total_price}₽\n"
    text += f"💰 **Средняя цена:** {avg_price}₽\n"
    text += f"📦 **Общее количество:** {total_count}\n\n"
    
    text += f"📂 **Категории:**\n"
    for cat, count in categories.items():
        cat_escaped = escape_markdown(cat)
        text += f"   • {cat_escaped}: {count} лотов\n"
    
    kb = InlineKeyboardMarkup()
    kb.add(InlineKeyboardButton("◀️ Назад к списку", callback_data=f"{CBT_LOT_BACK}:0:all"))
    
    bot.send_message(message.chat.id, text, reply_markup=kb, parse_mode="Markdown")

def handle_lot_action(call, action, lot_id, page, filter_type="all"):
    if action == "status":
        lots = get_cached_lots() or get_lots_from_profile()
        lot = next((l for l in lots if l.get("id") == lot_id), None)
        if lot:
            new_status = not lot.get('active', False)
            if update_lot(lot_id, active=new_status):
                status_text = "активирован" if new_status else "деактивирован"
                bot.answer_callback_query(call.id, f"✅ Лот {status_text}")
            else:
                bot.answer_callback_query(call.id, "❌ Ошибка обновления")
        show_lots_menu(call.message, int(page), filter_type)

def handle_input(message):
    state = tg.get_state(message.chat.id, message.from_user.id)
    if not state:
        return
    
    action = state["action"]
    data = state["data"]
    page = data.get("page", 0)
    filter_type = data.get("filter_type", "all")
    
    try:
        if action == WAITING_CATEGORY_ID:
            category_id = message.text.strip()
            if category_id.isdigit():
                bot.reply_to(message, f"🔍 Сканирую категорию {category_id}...")
                lots = get_lots_by_category(category_id)
                if lots:
                    bot.reply_to(message, f"✅ Найдено {len(lots)} лотов в категории {category_id}")
                else:
                    bot.reply_to(message, f"❌ Лотов не найдено в категории {category_id}")
                show_lots_menu(message, int(page), filter_type)
            else:
                bot.reply_to(message, "❌ Введите число (ID категории)!")
        
        elif action == WAITING_PRICE:
            price = int(message.text.strip())
            lot_id = data.get("lot_id")
            if update_lot(lot_id, price=price):
                bot.reply_to(message, f"✅ Цена обновлена: {price}₽")
            else:
                bot.reply_to(message, "❌ Ошибка обновления цены")
            show_lots_menu(message, int(page), filter_type)
        
        elif action == WAITING_COUNT:
            count = int(message.text.strip())
            lot_id = data.get("lot_id")
            if update_lot(lot_id, count=count):
                bot.reply_to(message, f"✅ Количество обновлено: {count}")
            else:
                bot.reply_to(message, "❌ Ошибка обновления количества")
            show_lots_menu(message, int(page), filter_type)
        
        elif action == WAITING_DESC:
            desc = message.text.strip()
            lot_id = data.get("lot_id")
            if update_lot(lot_id, description=desc):
                bot.reply_to(message, "✅ Описание обновлено")
            else:
                bot.reply_to(message, "❌ Ошибка обновления описания")
            show_lots_menu(message, int(page), filter_type)
        
        elif action == WAITING_SHORT:
            short = message.text.strip()
            lot_id = data.get("lot_id")
            if update_lot(lot_id, short_desc=short):
                bot.reply_to(message, "✅ Краткое описание обновлено")
            else:
                bot.reply_to(message, "❌ Ошибка обновления краткого описания")
            show_lots_menu(message, int(page), filter_type)
    
    except ValueError:
        bot.reply_to(message, "❌ Введите число!")
    except Exception as e:
        bot.reply_to(message, f"❌ Ошибка: {e}")
    
    tg.clear_state(message.chat.id, message.from_user.id)

