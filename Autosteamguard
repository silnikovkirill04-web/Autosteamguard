    bot.send_message(message.chat.id, text, reply_markup=kb)

# ============================================
# 🚀 ИНИЦИАЛИЗАЦИЯ
# ============================================

def init_plugin(c):
    global cardinal, tg, bot, idle_thread_running
    cardinal = c
    tg = c.telegram
    bot = c.telegram.bot
    load_config()
    
    ok, count = check_mail()
    print(f"[SteamGuard] {'✅' if ok else '❌'} Почта | Писем: {count}")
    print(f"[SteamGuard] 📡 Запуск IMAP IDLE...")
    
    if not idle_thread_running:
        idle_thread = threading.Thread(target=idle_worker, daemon=True)
        idle_thread.start()
        idle_thread_running = True
        print(f"[SteamGuard] 📡 IDLE поток запущен")
    
    c.add_telegram_commands(UUID, [
        ("sg", "🔐 SteamGuard", True),
        ("test_sgk", "🧪 Тест писем Steam", True)
    ])
    tg.msg_handler(show_menu, commands=["sg"])
    tg.msg_handler(test_steam_mail, commands=["test_sgk"])
    
    @bot.callback_query_handler(func=lambda call: call.data == "sg_toggle")
    def toggle(call):
        SETTINGS["active"] = not SETTINGS["active"]
        save_config()
        bot.answer_callback_query(call.id, f"{'ON' if SETTINGS['active'] else 'OFF'}")
        show_menu(call.message)
    
    @bot.callback_query_handler(func=lambda call: call.data == "sg_toggle_delete")
    def toggle_delete(call):
        SETTINGS["delete_after_use"] = not SETTINGS.get("delete_after_use", True)
        save_config()
        bot.answer_callback_query(call.id, f"{'ВКЛ' if SETTINGS['delete_after_use'] else 'ВЫКЛ'}")
        show_menu(call.message)
    
    @bot.callback_query_handler(func=lambda call: call.data == "sg_refresh")
    def refresh(call):
        bot.answer_callback_query(call.id, "Обновляю...")
        show_menu(call.message)
    
    threading.Thread(target=chat_scanner, daemon=True).start()
    print(f"[SteamGuard v{VERSION}] ✅ Загружен. Ultra-режим активен!")

BIND_TO_PRE_INIT = [init_plugin]
BIND_TO_DELETE = None
