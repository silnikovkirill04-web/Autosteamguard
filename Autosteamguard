    if code:
        SETTINGS["issued_codes"][code] = {
            "time": datetime.now().strftime("%d.%m.%Y %H:%M:%S"),
            "chat_id": chat_id
        }
        save_config()
        
        cardinal.send_message(chat_id,
            f"🎉 Код найден!\n\n"
            f"🔐 Код: {code}"
        )
        print(f"[SG] ✅ Код {code} отправлен {chat_id}")
    else:
        cardinal.send_message(chat_id,
            f"❌ Код не найден.\n"
            f"🔄 Попробуйте еще раз через 10 секунд."
        )
        print(f"[SG] ❌ Код не найден для {chat_id}")

