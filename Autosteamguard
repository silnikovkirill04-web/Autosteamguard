def fetch_code_idle(conn):
    """Поиск кода через IDLE соединение"""
    try:
        _, mail_ids = conn.search(None, f'UNSEEN FROM "{SETTINGS["steam_sender"]}"')
        if not mail_ids[0]:
            return None
        
        mail_id = mail_ids[0].split()[-1]
        _, raw = conn.fetch(mail_id, "(RFC822)")
        mail_obj = email.message_from_bytes(raw[0][1])
        
        subject = mail_obj.get("Subject", "").lower()
        if any(w in subject for w in BLOCKED_SUBJECTS):
            return None
        
        body = ""
        if mail_obj.is_multipart():
            for part in mail_obj.walk():
                if part.get_content_type() == "text/plain":
                    body = part.get_payload(decode=True).decode("utf-8", errors="ignore")
                    break
        else:
            body = mail_obj.get_payload(decode=True).decode("utf-8", errors="ignore")
        
        body_lower = body.lower()
        
        if any(w in body_lower for w in BLOCKED_BODY):
            return None
        
        code_match = re.search(r'^\s*([A-Z0-9]{5})\s*$', body, re.MULTILINE)
        if not code_match:
            code_match = re.search(r'код\s*[:.]?\s*([A-Z0-9]{5})', body_lower)
        if not code_match:
            code_match = re.search(r'\b([A-Z0-9]{5})\b', body)
        
        if code_match:
            code = code_match.group(1) if len(code_match.groups()) > 0 else code_match.group(0)
            code = code.upper()
            
            if any(kw in body_lower for kw in GUARD_KEYWORDS):
                if SETTINGS.get("delete_after_use", True):
                    conn.store(mail_id, "+FLAGS", "\\Deleted")
                    conn.expunge()
                    print("[SG] 🗑️ Письмо удалено после выдачи")
                else:
                    conn.store(mail_id, "+FLAGS", "\\Seen")
                return code
        
        return None
    except Exception as e:
        print(f"[SG] Ошибка fetch_code_idle: {e}")
        return None

