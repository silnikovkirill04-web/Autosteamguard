def show_stats(message):
    """Показывает статистику по лотам"""
    lots = get_cached_lots() or get_lots_from_profile()
    if not lots:
        cardinal.send_message(message.chat.id, "❌ Нет данных. Нажмите 'Загрузить лоты'")
        return
    
    total = len(lots)
    active = len([l for l in lots if l["active"]])
    inactive = len([l for l in lots if not l["active"]])
    
    total_price = sum(l["price"] for l in lots)
    total_count = sum(l["count"] for l in lots)
    avg_price = total_price // total if total > 0 else 0
    
    categories = {}
    for lot in lots:
        cat = lot.get("category", "Без категории")
        categories[cat] = categories.get(cat, 0) + 1
    
    text = f"📊 **Статистика лотов**\n\n"
    text += f"📌 **Всего лотов:** {total}\n"
    text += f"🟢 **Активных:** {active}\n"
    text += f"🔴 **Неактивных:** {inactive}\n"
    text += f"💰 **Общая стоимость:** {total_price}₽\n"
    text += f"💰 **Средняя цена:** {avg_price}₽\n"
    text += f"📦 **Общее количество:** {total_count}\n\n"
    
    text += f"📂 **Категории:**\n"
    for cat, count in categories.items():
        cat_escaped = escape_markdown(cat)
        text += f"   • {cat_escaped}: {count} лотов\n"
    
    kb = InlineKeyboardMarkup()
    kb.add(InlineKeyboardButton("◀️ Назад к списку", callback_data=f"{CBT_LOT_BACK}:0:all"))
    
    cardinal.send_message(message.chat.id, text, reply_markup=kb, parse_mode="Markdown")

