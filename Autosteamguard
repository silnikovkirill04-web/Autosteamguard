def handle_input(message):
    state = tg.get_state(message.chat.id, message.from_user.id)
    if not state:
        return
    
    action = state["action"]
    data = state["data"]
    lot_index = data.get("lot_index", 0)
    field = data.get("field", "")
    
    try:
        if action == WAITING_PRICE:
            price = int(message.text.strip())
            lots = load_cache()
            if lots and lot_index < len(lots):
                lot = lots[lot_index]
                offer_id = get_lot_offer_id(lot)
                
                # Обновляем через API
                fields = cardinal.account.get_lot_fields(offer_id)
                if fields:
                    fields.price = float(price)
                    fields.renew_fields()
                    cardinal.account.save_lot(fields)
                    
                    # Обновляем кэш
                    lot["price"] = str(price)
                    save_cache(lots)
                    bot.reply_to(message, f"✅ Цена обновлена: {price}₽")
                else:
                    bot.reply_to(message, "❌ Не удалось получить поля лота")
            show_lots_menu(message)
        
        elif action == WAITING_COUNT:
            count = int(message.text.strip())
            lots = load_cache()
            if lots and lot_index < len(lots):
                lot = lots[lot_index]
                offer_id = get_lot_offer_id(lot)
                
                fields = cardinal.account.get_lot_fields(offer_id)
                if fields:
                    fields.amount = count
                    fields.renew_fields()
                    cardinal.account.save_lot(fields)
                    
                    lot["amount"] = str(count)
                    save_cache(lots)
                    bot.reply_to(message, f"✅ Количество обновлено: {count}")
                else:
                    bot.reply_to(message, "❌ Не удалось получить поля лота")
            show_lots_menu(message)
        
        elif action == WAITING_DESC:
            desc = message.text.strip()
            lots = load_cache()
            if lots and lot_index < len(lots):
                lot = lots[lot_index]
                offer_id = get_lot_offer_id(lot)
                
                fields = cardinal.account.get_lot_fields(offer_id)
                if fields:
                    fields.description = desc
                    fields.renew_fields()
                    cardinal.account.save_lot(fields)
                    
                    lot["name"] = desc
                    save_cache(lots)
                    bot.reply_to(message, "✅ Описание обновлено")
                else:
                    bot.reply_to(message, "❌ Не удалось получить поля лота")
            show_lots_menu(message)
    
    except ValueError:
        bot.reply_to(message, "❌ Введите число!")
    except Exception as e:
        bot.reply_to(message, f"❌ Ошибка: {e}")
    
    tg.clear_state(message.chat.id, message.from_user.id)

def handle_lot_action(call, action, lot_index):
    lots = load_cache()
    if not lots or lot_index >= len(lots):
        bot.answer_callback_query(call.id, "❌ Лот не найден")
        return
    
    lot = lots[lot_index]
    offer_id = get_lot_offer_id(lot)
    
    if action == "status":
        try:
            new_status = not get_lot_active(lot)
            
            fields = cardinal.account.get_lot_fields(offer_id)
            if fields:
                fields.active = new_status
                fields.renew_fields()
                cardinal.account.save_lot(fields)
                
                lot["active"] = "on" if new_status else ""
                save_cache(lots)
                
                status_text = "активирован" if new_status else "деактивирован"
                bot.answer_callback_query(call.id, f"✅ Лот {status_text}")
            else:
                bot.answer_callback_query(call.id, "❌ Не удалось получить поля лота")
        except Exception as e:
            bot.answer_callback_query(call.id, f"❌ Ошибка: {e}")
        show_lots_menu(call.message)
    
    elif action == "delete":
        try:
            cardinal.account.delete_lot(offer_id)
            lots.pop(lot_index)
            save_cache(lots)
            bot.answer_callback_query(call.id, "🗑️ Лот удален!")
            show_lots_menu(call.message)
        except Exception as e:
            bot.answer_callback_query(call.id, f"❌ Ошибка удаления: {e}")

def show_stats(message):
    lots = load_cache()
    if not lots:
        bot.send_message(message.chat.id, "❌ Нет данных. Нажмите 'Скачать'")
        return
    
    total = len(lots)
    active = len([l for l in lots if get_lot_active(l)])
    inactive = len([l for l in lots if not get_lot_active(l)])
    
    total_price = sum(int(get_lot_price(l)) for l in lots)
    total_count = sum(int(get_lot_amount(l)) for l in lots)
    avg_price = total_price // total if total > 0 else 0
    
    text = f"📊 **Статистика лотов**\n\n"
    text += f"📌 **Всего лотов:** {total}\n"
    text += f"🟢 **Активных:** {active}\n"
    text += f"🔴 **Неактивных:** {inactive}\n"
    text += f"💰 **Общая стоимость:** {total_price}₽\n"
    text += f"💰 **Средняя цена:** {avg_price}₽\n"
    text += f"📦 **Общее количество:** {total_count}\n"
    
    kb = InlineKeyboardMarkup()
    kb.add(InlineKeyboardButton("◀️ Назад к списку", callback_data=f"{CBT_LOT_BACK}:0:all"))
    
    bot.send_message(message.chat.id, text, reply_markup=kb, parse_mode="Markdown")

