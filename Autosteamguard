def load_config():
    global SETTINGS
    try:
        if os.path.exists(CONFIG_PATH):
            with open(CONFIG_PATH, "r", encoding="utf-8") as f:
                loaded = json.load(f)
                for k in loaded:
                    if k in SETTINGS:
                        SETTINGS[k] = loaded[k]
        else:
            save_config()
    except Exception as e:
        print(f"[LM] ❌ Ошибка загрузки конфига: {e}")
        save_config()

def save_config():
    try:
        os.makedirs(os.path.dirname(CONFIG_PATH), exist_ok=True)
        with open(CONFIG_PATH, "w", encoding="utf-8") as f:
            json.dump(SETTINGS, f, indent=4, ensure_ascii=False)
    except Exception as e:
        print(f"[LM] ❌ Ошибка сохранения: {e}")

def load_cache():
    """Загружает кэш лотов"""
    try:
        if os.path.exists(LOTS_CACHE_PATH):
            with open(LOTS_CACHE_PATH, "r", encoding="utf-8") as f:
                return json.load(f)
    except Exception as e:
        print(f"[LM] ❌ Ошибка загрузки кэша: {e}")
    return []

def save_cache(data):
    """Сохраняет кэш лотов"""
    try:
        os.makedirs(os.path.dirname(LOTS_CACHE_PATH), exist_ok=True)
        with open(LOTS_CACHE_PATH, "w", encoding="utf-8") as f:
            json.dump(data, f, ensure_ascii=False, indent=2)
        print(f"[LM] ✅ Сохранено {len(data)} лотов в кэш")
    except Exception as e:
        print(f"[LM] ❌ Ошибка сохранения кэша: {e}")

def escape_markdown(text):
    if not text:
        return ""
    escape_chars = r'_*[]()~`>#+-=|{}.!'
    return ''.join(f'\\{c}' if c in escape_chars else c for c in text)

