def load_config():
    global SETTINGS
    try:
        if os.path.exists(CONFIG_PATH):
            with open(CONFIG_PATH, "r", encoding="utf-8") as f:
                loaded = json.load(f)
                for k in loaded:
                    if k in SETTINGS:
                        SETTINGS[k] = loaded[k]
        else:
            save_config()
    except Exception as e:
        print(f"[LM] ❌ Ошибка загрузки конфига: {e}")
        save_config()

def save_config():
    try:
        os.makedirs(os.path.dirname(CONFIG_PATH), exist_ok=True)
        with open(CONFIG_PATH, "w", encoding="utf-8") as f:
            json.dump(SETTINGS, f, indent=4, ensure_ascii=False)
    except Exception as e:
        print(f"[LM] ❌ Ошибка сохранения: {e}")

def escape_markdown(text):
    """Экранирует спецсимволы для Markdown"""
    if not text:
        return ""
    escape_chars = r'_*[]()~`>#+-=|{}.!'
    return ''.join(f'\\{c}' if c in escape_chars else c for c in text)

def get_lots_from_profile():
    """Загружает лоты из профиля FunPay с принудительным обновлением"""
    try:
        print("[LM] 🔄 Загрузка лотов из профиля...")
        
        # 🔥 ПРОВЕРКА АВТОРИЗАЦИИ
        if not cardinal.account or not cardinal.account.golden_key:
            print("[LM] ❌ Аккаунт не авторизован (нет golden_key)")
            print("[LM] 💡 Подожди 15-20 секунд после старта Cardinal")
            return []
        
        # 🔥 ПРИНУДИТЕЛЬНОЕ ОБНОВЛЕНИЕ
        lots = None
        
        # Вариант 1: force_download
        try:
            lots = cardinal.account.get_lots(force_download=True)
            if lots:
                print(f"[LM] ✅ Загружено {len(lots)} лотов (force_download)")
        except TypeError:
            pass
        
        # Вариант 2: load_lots
        if lots is None:
            try:
                if hasattr(cardinal.account, 'load_lots'):
                    cardinal.account.load_lots()
                    lots = cardinal.account.get_lots()
                    if lots:
                        print(f"[LM] ✅ Загружено {len(lots)} лотов (load_lots)")
            except Exception as e:
                print(f"[LM] ⚠️ load_lots не сработал: {e}")
        
        # Вариант 3: обычный get_lots
        if lots is None:
            try:
                lots = cardinal.account.get_lots()
                if lots:
                    print(f"[LM] ✅ Загружено {len(lots)} лотов (базовый)")
            except Exception as e:
                print(f"[LM] ❌ Ошибка get_lots: {e}")
        
        if not lots:
            print("[LM] ❌ Лотов не найдено.")
            print("[LM] 💡 Проверь:")
            print("[LM]    1. Консоль Cardinal на ошибки (Cloudflare, 403)")
            print("[LM]    2. Golden_key в настройках Cardinal")
            print("[LM]    3. Подожди 15-20 секунд после запуска")
            return []
        
        result = []
        for lot in lots:
            lot_data = {
                "id": lot.id,
                "name": lot.name,
                "price": lot.price,
                "count": lot.count,
                "active": lot.active,
                "description": lot.description or "",
                "short_desc": getattr(lot, 'short_description', '') or "",
                "category": getattr(lot, 'category', 'Без категории') or "Без категории",
                "updated": datetime.now().strftime("%d.%m.%Y %H:%M:%S")
            }
            result.append(lot_data)
            
            # Сохраняем в кэш
            SETTINGS["lots_cache"][lot.id] = lot_data
        
        save_config()
        print(f"[LM] ✅ Сохранено {len(result)} лотов в кэш")
        return result
        
    except Exception as e:
        print(f"[LM] ❌ Ошибка загрузки лотов: {e}")
        print(f"[LM] 💡 Проверь консоль Cardinal на ошибки")
        import traceback
        traceback.print_exc()
        return []

def get_cached_lots():
    """Возвращает лоты из кэша"""
    return list(SETTINGS.get("lots_cache", {}).values())

def update_lot(lot_id, **kwargs):
    """Обновляет параметры лота"""
    try:
        lot = cardinal.account.get_lot(lot_id)
        if not lot:
            print(f"[LM] ❌ Лот {lot_id} не найден")
            return False
        
        for key, value in kwargs.items():
            if key == "price":
                lot.price = value
            elif key == "count":
                lot.count = value
            elif key == "active":
                lot.active = value
            elif key == "description":
                lot.description = value
            elif key == "short_desc":
                lot.short_description = value
        
        # Используем save_lot через аккаунт
        cardinal.account.save_lot(lot)
        
        # Обновляем кэш
        if lot_id in SETTINGS["lots_cache"]:
            for key, value in kwargs.items():
                if key in SETTINGS["lots_cache"][lot_id]:
                    SETTINGS["lots_cache"][lot_id][key] = value
            SETTINGS["lots_cache"][lot_id]["updated"] = datetime.now().strftime("%d.%m.%Y %H:%M:%S")
            save_config()
        
        print(f"[LM] ✅ Лот {lot_id} обновлен")
        return True
        
    except Exception as e:
        print(f"[LM] ❌ Ошибка обновления лота {lot_id}: {e}")
        return False

def format_lot_name(name, active=True, max_len=35):
    """Форматирует название лота с указанием статуса"""
    display = escape_markdown(name[:max_len] + "..." if len(name) > max_len else name)
    if active:
        return f"🟢 `{display}`"
    else:
        return f"🔴 `{display}`"

