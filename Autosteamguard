def fetch_code():
    """Поиск кода в непрочитанных письмах от Steam"""
    conn = get_imap()
    if not conn:
        return None
    
    try:
        _, mail_ids = conn.search(None, f'UNSEEN FROM "{SETTINGS["steam_sender"]}"')
        
        if not mail_ids or not mail_ids[0] or mail_ids[0] == b'':
            conn.close()
            conn.logout()
            return None
        
        print(f"[SG] 📬 Найдено {len(mail_ids[0].split())} новых писем от Steam")
        
        for mail_id in reversed(mail_ids[0].split()[-5:]):
            try:
                _, raw = conn.fetch(mail_id, "(RFC822)")
                mail_obj = email.message_from_bytes(raw[0][1])
                
                subject = mail_obj.get("Subject", "Без темы")
                subject_lower = subject.lower()
                
                body = ""
                if mail_obj.is_multipart():
                    for part in mail_obj.walk():
                        if part.get_content_type() == "text/plain":
                            body = part.get_payload(decode=True).decode("utf-8", errors="ignore")
                            break
                else:
                    body = mail_obj.get_payload(decode=True).decode("utf-8", errors="ignore")
                
                body_lower = body.lower()
                
                # Проверка на опасность
                if is_dangerous_email(body_lower, subject_lower):
                    print(f"[SG] 🚫 Опасное письмо: {subject[:50]}")
                    conn.store(mail_id, "+FLAGS", "\\Deleted")
                    conn.expunge()
                    continue
                
                # Ищем код
                codes = re.findall(r"\b[A-Z0-9]{5}\b", body)
                
                if codes and any(kw in body_lower for kw in GUARD_KEYWORDS):
                    code = codes[0].upper()
                    print(f"[SG] 🎉 КОД НАЙДЕН: {code}")
                    
                    if SETTINGS.get("delete_after_use", True):
                        conn.store(mail_id, "+FLAGS", "\\Deleted")
                        conn.expunge()
                        print(f"[SG] 🗑️ Письмо с кодом {code} УДАЛЕНО")
                    
                    conn.close()
                    conn.logout()
                    return code
                    
            except Exception as e:
                print(f"[SG] ❌ Ошибка обработки письма: {e}")
                continue
        
        conn.close()
        conn.logout()
        return None
        
    except Exception as e:
        print(f"[SG] ❌ Критическая ошибка: {e}")
        try:
            conn.close()
            conn.logout()
        except:
            pass
        return None

