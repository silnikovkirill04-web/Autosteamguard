def show_lots_menu(message, page=0, filter_type="all"):
    loading_msg = bot.send_message(message.chat.id, "⏳ Загрузка лотов...")
    lots = get_cached_lots()
    
    if not lots:
        bot.edit_message_text("🔄 Кэш пуст, сканирую категории...", message.chat.id, loading_msg.id)
        lots = get_lots_from_profile()
    
    if not lots:
        bot.edit_message_text("❌ Лотов не найдено", message.chat.id, loading_msg.id)
        kb = InlineKeyboardMarkup(row_width=2)
        kb.row(
            InlineKeyboardButton("🔍 Сканировать все", callback_data=f"{CBT_LOT_SCAN}:0:all"),
            InlineKeyboardButton("📂 По ID игры", callback_data=f"{CBT_LOT_SCAN_CATEGORY}:0:all")
        )
        kb.add(InlineKeyboardButton("📝 Создать лот на FunPay", url="https://funpay.com/sell/"))
        bot.send_message(
            message.chat.id,
            "❌ Лотов не найдено.\n\n"
            "🔍 Сканировать все категории\n"
            "📂 Или ввести ID конкретной игры",
            reply_markup=kb
        )
        return
    
    bot.delete_message(message.chat.id, loading_msg.id)
    
    if filter_type == "active":
        filtered = [l for l in lots if l.get("active", False)]
    elif filter_type == "inactive":
        filtered = [l for l in lots if not l.get("active", False)]
    else:
        filtered = lots
    
    active_lots = [l for l in filtered if l.get("active", False)]
    inactive_lots = [l for l in filtered if not l.get("active", False)]
    sorted_lots = active_lots + inactive_lots
    
    per_page = 5
    total_pages = (len(sorted_lots) + per_page - 1) // per_page
    if total_pages == 0:
        total_pages = 1
    if page >= total_pages:
        page = total_pages - 1
    if page < 0:
        page = 0
    
    start = page * per_page
    end = min(start + per_page, len(sorted_lots))
    page_lots = sorted_lots[start:end]
    
    total = len(lots)
    total_active = len([l for l in lots if l.get("active", False)])
    total_inactive = len([l for l in lots if not l.get("active", False)])
    
    filter_names = {
        "all": "Все",
        "active": "🟢 Активные",
        "inactive": "🔴 Неактивные"
    }
    
    text = f"📋 **Список лотов**\n"
    text += f"📂 {filter_names.get(filter_type, 'Все')} | стр. {page + 1}/{total_pages}\n"
    text += f"📊 Всего: {total} | 🟢 Активных: {total_active} | 🔴 Неактивных: {total_inactive}\n\n"
    
    if not page_lots:
        text += "❌ Нет лотов в этой категории\n"
    else:
        for i, lot in enumerate(page_lots, start + 1):
            name = escape_markdown(lot.get('name', 'Без названия'))
            category = escape_markdown(lot.get('category', 'Без категории'))
            status_icon = "🟢" if lot.get('active', False) else "🔴"
            status_text = "Активен" if lot.get('active', False) else "Неактивен"
            
            text += f"**{i}. {status_icon} `{name}`**\n"
            text += f"   💰 {lot.get('price', 0)}₽ | 📦 {lot.get('count', 0)} шт.\n"
            text += f"   📌 {status_icon} {status_text}\n"
            text += f"   📂 {category}\n"
            text += f"   🆔 `{lot.get('id', '')}`\n\n"
    
    kb = InlineKeyboardMarkup(row_width=3)
    
    kb.row(
        InlineKeyboardButton("📂 Все", callback_data=f"{CBT_LOT_FILTER}:all:{page}"),
        InlineKeyboardButton("🟢 Активные", callback_data=f"{CBT_LOT_FILTER}:active:{page}"),
        InlineKeyboardButton("🔴 Неактивные", callback_data=f"{CBT_LOT_FILTER}:inactive:{page}")
    )
    
    nav_buttons = []
    if page > 0:
        nav_buttons.append(InlineKeyboardButton("◀️", callback_data=f"{CBT_LOT_PAGE}:{page - 1}:{filter_type}"))
    if page < total_pages - 1:
        nav_buttons.append(InlineKeyboardButton("▶️", callback_data=f"{CBT_LOT_PAGE}:{page + 1}:{filter_type}"))
    if nav_buttons:
        kb.row(*nav_buttons)
    
    for lot in page_lots:
        lot_id = lot.get("id", "")
        name_short = escape_markdown(lot.get('name', 'Без названия')[:12])
        status_btn = "🔴 Выкл" if lot.get('active', False) else "🟢 Вкл"
        kb.row(
            InlineKeyboardButton(f"✏️ {name_short}", callback_data=f"{CBT_LOT_EDIT}:{lot_id}:{page}:{filter_type}"),
            InlineKeyboardButton(f"{status_btn}", callback_data=f"{CBT_LOT_STATUS}:{lot_id}:{page}:{filter_type}"),
            InlineKeyboardButton("🗑️", callback_data=f"{CBT_LOT_DELETE}:{lot_id}:{page}:{filter_type}")
        )
    
    kb.row(
        InlineKeyboardButton("🔄 Обновить", callback_data=f"{CBT_LOT_REFRESH}:{page}:{filter_type}"),
        InlineKeyboardButton("🔍 Все категории", callback_data=f"{CBT_LOT_SCAN}:{page}:{filter_type}"),
