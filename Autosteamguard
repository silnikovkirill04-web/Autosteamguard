def start_session(chat_id):
    """Запускает сессию для клиента (10 минут)"""
    SETTINGS["active_sessions"][str(chat_id)] = {
        "start": time.time(),
        "timeout": SETTINGS.get("session_timeout", 600),
        "notified": False
    }
    save_config()

def check_sessions():
    """Проверяет активные сессии"""
    now = time.time()
    for chat_id, session in list(SETTINGS["active_sessions"].items()):
        elapsed = now - session["start"]
        timeout = session["timeout"]
        
        if elapsed > timeout - 60 and not session.get("notified"):
            session["notified"] = True
            save_config()
            cardinal.send_message(int(chat_id),
                f"⚠️ Внимание!\n\n"
                f"У вас осталась 1 минута на настройку аккаунта.\n"
                f"⏰ Сессия истекает через 60 секунд."
            )
        
        if elapsed > timeout:
            del SETTINGS["active_sessions"][chat_id]
            save_config()
            cardinal.send_message(int(chat_id),
                f"⏰ Ваше время на настройку вышло!\n\n"
                f"🔄 Для повторного входа запросите новый код командой SGC."
            )
            print(f"[SG] ⏰ Сессия для {chat_id} истекла")

